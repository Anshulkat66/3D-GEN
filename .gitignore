# --- PYTHON JUNK ---
# These are files your computer creates to run Python faster
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- ENVIRONMENTS ---
# This prevents your entire Anaconda environment from being uploaded
.conda/
.env
venv/
env/
ENV/

# --- IDE & SYSTEM ---
# Settings specific to your VS Code or Windows
.vscode/
.history/
Thumbs.db
.DS_Store

# --- MODEL WEIGHTS ---
# If you train a model, don't upload the large .pth or .h5 files
*.pth
*.h5
*.ckpt
